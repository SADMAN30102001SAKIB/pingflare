{
  "name": "pingflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n pages,worker -c cyan,green \"pnpm dev:pages\" \"pnpm dev:worker\"",
    "dev:pages": "vite --host 0.0.0.0",
    "dev:worker": "wrangler dev --test-scheduled --port 8787",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty",
    "lint": "eslint .",
    "format": "prettier --write .",
    "deploy:worker": "wrangler deploy",
    "deploy:pages": "wrangler pages deploy dist --project-name pingflare",
    "db:migrate:local": "wrangler d1 migrations apply pingflare --local",
    "db:migrate:remote": "wrangler d1 migrations apply pingflare --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.5",
    "@tanstack/react-router": "^1.141.2",
    "hono": "^4.11.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251225.0",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "wrangler": "^4.54.0"
  }
}
